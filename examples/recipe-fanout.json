{
  "version": "0",
  "tools": {
    "echo": {
      "adapter": "local",
      "effects": {
        "pure": true,
        "idempotent": true,
        "cacheable": true,
        "batchable": true
      }
    }
  },
  "recipe": {
    "kind": "fan_out",
    "tool": "echo",
    "items": [
      { "sleep_ms": 50, "path": "README.md" },
      { "sleep_ms": 50, "path": "Cargo.toml" },
      { "sleep_ms": 50, "path": "package.json" }
    ],
    "node_prefix": "file_"
  },
  "outputs": {
    "first": "file_1.output"
  }
}
