{
  "version": "0",
  "tools": {
    "echo": {
      "adapter": "local",
      "effects": {
        "pure": true,
        "idempotent": true,
        "cacheable": true,
        "batchable": true
      }
    }
  },
  "recipe": {
    "kind": "fan_out",
    "tool": "echo",
    "items": ["README.md", "Cargo.toml", "package.json"],
    "node_prefix": "file_",
    "input_key": "path"
  },
  "outputs": {
    "first": "file_1.output"
  }
}
