{
  "name": "recipe-fanout-static",
  "recipe": {
    "version": "0",
    "name": "read docs",
    "tools": {
      "read": {
        "adapter": "fs.repo",
        "effects": {
          "pure": false,
          "reads": ["file:{path}"],
          "writes": [],
          "idempotent": true,
          "cacheable": true,
          "batchable": true,
          "commutative": false
        }
      }
    },
    "recipe": {
      "kind": "fan_out",
      "tool": "read",
      "items": ["a.md", "b.md"],
      "node_prefix": "read_",
      "input_key": "path"
    },
    "outputs": { "first": "read_1.output" }
  },
